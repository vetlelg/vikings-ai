# Viking Settlement — Environment Variables
# Copy this file to .env and edit as needed.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Engine
TICK_RATE_MS=5000

# LLM Provider: "stub", "claude", "gemini", "groq"
LLM_PROVIDER=stub
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=

# Bridge
BRIDGE_PORT=8080
